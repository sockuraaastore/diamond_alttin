{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and credentials",
      "type": "object",
      "properties": {
        "username": { "type": "string", "description": "Unique username" },
        "password": { "type": "string", "description": "User password" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "integer" }
      },
      "required": ["username", "password", "role", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["name", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Product details",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "integer" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["title", "description", "categoryId", "categoryName", "price", "stock", "imageUrl", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "User shopping orders",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "postalCode": { "type": "string" },
        "receiptUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "deliveryInfo": { "type": "string" },
        "rejectReason": { "type": "string" },
        "items": { "type": "array" },
        "createdAt": { "type": "integer" }
      },
      "required": ["userId", "username", "phone", "address", "postalCode", "receiptUrl", "status", "items", "createdAt"]
    },
    "Ticket": {
      "title": "Ticket",
      "description": "Customer support tickets",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "reply": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "replied"] },
        "createdAt": { "type": "integer" }
      },
      "required": ["userId", "username", "subject", "message", "status", "createdAt"]
    },
    "Banner": {
      "title": "Banner",
      "description": "Hero banner slides",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["imageUrl", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Product reviews and comments",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "username": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["productId", "username", "text", "createdAt"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Registered application users"
    },
    "categories": {
      "schema": "Category",
      "description": "Product categories"
    },
    "products": {
      "schema": "Product",
      "description": "Store products"
    },
    "orders": {
      "schema": "Order",
      "description": "Customer purchase orders"
    },
    "tickets": {
      "schema": "Ticket",
      "description": "Support tickets"
    },
    "banners": {
      "schema": "Banner",
      "description": "Slideshow banners"
    },
    "comments": {
      "schema": "Comment",
      "description": "User reviews on products"
    }
  }
}
